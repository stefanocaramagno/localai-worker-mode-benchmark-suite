{
  "schemaVersion": "cluster-lens-capture-profile/v1",
  "schemaPath": "config/cluster-lens/schemas/CLUSTER_LENS_PROFILE_SCHEMA_V1.json",
  "clusterLensProfileId": "CL_C9_PLACEMENT_SNAPSHOT",
  "profileName": "C9 cluster-lens placement snapshot capture",
  "profileStatus": "active",
  "profileRole": "network_aware_scheduler_placement_evidence_capture",
  "purpose": "Capture cluster-lens topology snapshots and Kubernetes placement evidence for gateway-routed network-aware scheduler variants.",
  "cycleId": "C9",
  "cycleConfigPath": "config/experimental-cycles/C9.json",
  "scenarioIndexPath": "config/scenarios/network-aware-scheduler/NETWORK_AWARE_SCHEDULER_SCENARIOS_INDEX.json",
  "infrastructureProfileId": "INFRA_C9_1CP_4W_8C16G",
  "infrastructureProfilePath": "config/infrastructure/profiles/INFRA_C9_1CP_4W_8C16G.json",
  "kubeconfigPath": "config/cluster-access/generated/proxmox-k3s/c9-1cp-4w-8c16g/kubeconfig",
  "kubernetes": {
    "kubectl": "kubectl",
    "clusterLensNamespace": "observability",
    "clusterLensServiceName": "cluster-lens",
    "clusterLensServicePort": 8088,
    "clusterLensNodePort": 32088,
    "defaultAccessMode": "port_forward",
    "portForward": {
      "enabledByDefault": true,
      "localHost": "127.0.0.1",
      "localPort": 18088,
      "readyTimeoutSeconds": 30,
      "startupGraceSeconds": 1
    }
  },
  "clusterLens": {
    "providerAddon": "cluster_lens",
    "version": "v0.0.5",
    "apiPath": "/api/snapshot",
    "requestTimeoutSeconds": 15,
    "expectedSnapshotFields": [
      "generatedAt",
      "context",
      "nodes",
      "nodeEdges",
      "pods",
      "appEdges"
    ],
    "readOnlyCapture": true
  },
  "captureScope": {
    "tenantNamespacesOnly": true,
    "fallbackToAllNamespacesWhenScenarioNamespacesMissing": true,
    "includePods": true,
    "includeDeployments": true,
    "includeNodes": true,
    "includeClusterLensRawSnapshot": true,
    "includeUnscheduledPodsFromKubernetesSnapshot": true,
    "localAiAppNames": [
      "localai-server",
      "localai-rpc-a",
      "localai-rpc-b",
      "localai-rpc-c",
      "localai-rpc-d"
    ],
    "requiredDeploymentNamesPerTenant": [
      "localai-server",
      "localai-rpc-a",
      "localai-rpc-b"
    ]
  },
  "placementExtraction": {
    "tenantLabelKeys": [
      "group",
      "localai.benchmark/tenant"
    ],
    "roleLabelKeys": [
      "role",
      "localai.benchmark/role"
    ],
    "appLabelKeys": [
      "app",
      "app.kubernetes.io/name",
      "localai.benchmark/component"
    ],
    "workerIdLabelKeys": [
      "localai.benchmark/worker-id"
    ],
    "schedulerModeLabelKeys": [
      "localai.benchmark/scheduler-mode"
    ],
    "gatewayTrafficAnnotationKey": "traffic.localai-gateway-istio",
    "nodeAnnotationPrefixes": [
      "network-latency.",
      "packet-loss.",
      "network-bandwidth."
    ],
    "deploymentAnnotationPrefixes": [
      "traffic.",
      "rps."
    ],
    "resolveDeploymentOwnerFromSelectors": true
  },
  "artifactPolicy": {
    "root": "results/experimental-cycles/C9/variants/__profile_default__/network-aware-scheduler/cluster-lens",
    "perVariantOutputRootRequired": true,
    "perVariantOutputRootPattern": "results/experimental-cycles/C9/variants/<scenario-id>/network-aware-scheduler/cluster-lens",
    "rawSnapshotFileName": "cluster-lens-snapshot.json",
    "podsSnapshotFileName": "cluster-lens-kubernetes-pods.json",
    "deploymentsSnapshotFileName": "cluster-lens-kubernetes-deployments.json",
    "nodesSnapshotFileName": "cluster-lens-kubernetes-nodes.json",
    "placementSummaryFileName": "cluster-lens-placement-summary.json",
    "placementSignatureFileName": "cluster-lens-placement-signature.csv",
    "captureManifestFileName": "cluster-lens-capture-manifest.json",
    "writeLatestAliases": false,
    "primaryStagePromotionManifestFileName": "cluster-lens-primary-stage-manifest.json",
    "primaryStagePromotionPolicy": "Preserve each capture under stages/<stage> and promote the selected primary stage artifacts to the cluster-lens root as the stable downstream evidence entry point."
  },
  "validationPolicy": {
    "requireClusterLensSnapshot": true,
    "requireKubernetesPodsSnapshot": true,
    "requireKubernetesDeploymentsSnapshot": true,
    "requireKubernetesNodesSnapshot": true,
    "requireAtLeastOneLocalAiPod": true,
    "requireTenantPlacementSummary": true,
    "treatClusterLensPodsAsAdvisory": true,
    "treatKubernetesSnapshotAsAuthoritativeForSchedulerName": true
  },
  "governance": {
    "installationBoundary": "cluster-lens is installed and exposed by the infrastructure provider. This profile captures the existing service and does not apply or modify cluster-lens manifests.",
    "evidenceBoundary": "cluster-lens provides topology and visual placement evidence. Kubernetes snapshots enrich that evidence with schedulerName, unscheduled pods, labels, annotations and deployment ownership.",
    "artifactBoundary": "All generated artifacts must be written under the active C9 variant output root and preserved by downstream diagnosis, reporting and freeze steps."
  }
}
