# -----------------------------------------------------------------------------
# Example kubeconfig template for local project setup.
# Copy this file to `config/cluster-access/kubeconfig` and replace all placeholder
# values with the real cluster-access data provided for your environment.
# Do not commit the real kubeconfig file to version control.
# -----------------------------------------------------------------------------
apiVersion: v1
kind: Config
clusters:
  - name: your-cluster
    cluster:
      server: https://your-cluster-endpoint:6443
      certificate-authority-data: <BASE64_CA_DATA>
contexts:
  - name: your-context
    context:
      cluster: your-cluster
      user: your-user
current-context: your-context
users:
  - name: your-user
    user:
      client-certificate-data: <BASE64_CLIENT_CERT_DATA>
      client-key-data: <BASE64_CLIENT_KEY_DATA>
preferences: {}
