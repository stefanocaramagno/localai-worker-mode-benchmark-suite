{
  "profileId": "TC_C1_PROVIDER_BACKED_BASELINE",
  "description": "Provider-backed benchmark technical pre-check profile for the C1 baseline on the proxmox-k3s generated cluster.",
  "kubeconfig": "config/cluster-access/generated/proxmox-k3s/c1-1cp-2w-8c16g/kubeconfig",
  "namespace": "localai-benchmark",
  "expectedReadyNodes": [
    "genai-pb-cp-01",
    "genai-pb-worker-01",
    "genai-pb-worker-02"
