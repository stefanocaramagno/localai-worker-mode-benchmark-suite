{
  "profileId": "MS_STANDARD_BENCHMARK_METRICS",
  "description": "Minimum mandatory metric set for all benchmark and validation runs. The profile fixes the canonical client-side and cluster-side metrics that must always be collected or derivable from run artifacts.",
  "clientMetrics": [
    "request_count",
    "success_rate_percent",
    "failure_count",
    "mean_response_time_ms",
    "p50_response_time_ms",
    "p95_response_time_ms",
    "p99_response_time_ms",
    "throughput_rps"
  ],
  "clusterMetrics": [
    "max_node_cpu_percent",
    "max_node_memory_percent",
    "node_cpu_percent",
    "node_memory_percent",
    "max_pod_cpu_millicores",
    "max_pod_memory_mib",
    "pod_cpu_millicores",
    "pod_memory_mib",
    "pod_placement",
    "pod_restart_count",
    "pod_readiness",
    "pending_pods_count",
    "failed_pods_count",
    "not_ready_pods_count",
    "kubernetes_events_count",
    "kubernetes_warning_events_count",
    "metrics_api_available"
  ],
  "metricSetManifestSuffix": "_metric-set.json",
  "metricSetTextSuffix": "_metric-set.txt",
  "schemaVersion": "metric-set-profile/v2",
  "minimalObservabilityIndexPath": "config/observability-minimal/MINIMAL_OBSERVABILITY_INDEX.json",
  "observabilityMode": "minimal_k3s_metrics_server",
  "artifactRequirements": {
    "clientSide": [
      "_stats.csv",
      "_stats_history.csv",
      "_failures.csv",
      "_exceptions.csv"
    ],
    "clusterSide": [
      "_nodes-wide.txt",
      "_nodes.json",
      "_top-nodes.txt",
      "_pods-wide.txt",
      "_pods.json",
      "_top-pods.txt",
      "_top-pods-containers.txt",
      "_services.txt",
      "_events.txt",
      "_events.json",
      "_pods-describe.txt"
    ],
    "minimalObservability": [
      "latest-minimal-observability-manifest.json",
      "latest-minimal-observability-summary.txt",
      "latest-minimal-observability-metrics.json"
    ]
  },
  "qualityGates": {
    "clientMetricsMustBeDerivableFromLocustStats": true,
    "clusterMetricsMustBeDerivableFromKubectlSnapshots": true,
    "missingOptionalClientCsvDoesNotFailCollection": true,
    "metricsServerWarningsMustBeRecorded": true,
    "pendingOrFailedPodsMustBeRecordedAsEvidence": true
  },
  "minimalObservabilityBindingPolicy": {
    "bindingMode": "cycle_or_runtime_profile",
    "description": "The metric set defines the canonical metrics and required artifact classes. Concrete minimal-observability profiles are resolved by the cycle profile or generated at runtime for campaign variants.",
    "defaultRuntimeTemplateId": "MO_PROVIDER_BACKED_OBSERVABILITY_TEMPLATE",
    "defaultRuntimeTemplatePath": "config/observability-minimal/templates/MO_PROVIDER_BACKED_OBSERVABILITY_TEMPLATE.json"
  }
}
