{
  "schemaVersion": "completion-gate-profile/v1",
  "completionGateProfileId": "CG_C6_MULTI_TENANCY",
  "profileId": "CG_C6_MULTI_TENANCY",
  "profileName": "C6 Multi-Tenancy Completion Gate Profile",
  "profileStatus": "active",
  "profileRole": "provider_backed_multi_tenancy_completion_gate",
  "description": "Completion gate profile for the provider-backed multi-tenancy campaign.",
  "cycleId": "C6",
  "cycleConfigPath": "config/experimental-cycles/C6.json",
  "baselineId": "B1",
  "baselineConfigPath": "config/scenarios/baseline/B1.json",
