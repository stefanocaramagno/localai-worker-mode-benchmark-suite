{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "BENCHMARK_RUNTIME_CONFIG_SCHEMA_V1",
  "title": "Benchmark Runtime Configuration Schema",
  "description": "Schema for provider-backed runtime benchmark profiles generated from a reference baseline and a scenario variant.",
  "type": "object",
  "required": [
    "baselineId",
    "benchmarkScenarioId",
    "benchmarkConfigId",
    "benchmarkConfigPath",
    "benchmarkRuntimeConfigSchemaId",
    "benchmarkRuntimeConfigSchemaPath",
    "scenarioId",
    "scenarioConfigPath",
    "referenceBaselineId",
    "referenceBaselineConfigPath",
    "referenceScenarioId",
    "referenceScenarioConfigPath",
    "baselineLineage",
    "modelScenario",
    "resolvedModelName",
    "workerScenario",
    "resolvedWorkerCount",
    "placementScenario",
    "resolvedPlacementType",
    "workloadScenario",
    "topologyDir",
    "serverManifest",
    "namespaceManifest",
    "storageManifest",
    "baseUrl",
    "prompt",
    "temperature",
    "requestTimeoutSeconds",
    "resultsRoot",
    "runtimeGeneration"
  ],
  "properties": {
    "baselineId": { "type": "string", "minLength": 1 },
    "benchmarkScenarioId": { "type": "string", "minLength": 1 },
    "benchmarkConfigId": { "type": "string", "minLength": 1 },
    "benchmarkConfigPath": { "type": "string", "minLength": 1 },
    "benchmarkConfigRole": { "type": "string" },
    "benchmarkRuntimeConfigSchemaId": { "const": "BENCHMARK_RUNTIME_CONFIG_SCHEMA_V1" },
    "benchmarkRuntimeConfigSchemaPath": { "type": "string", "minLength": 1 },
    "scenarioId": { "type": "string", "minLength": 1 },
    "variantId": { "type": "string" },
    "family": { "type": "string" },
    "scenarioConfigPath": { "type": "string", "minLength": 1 },
    "referenceBaselineId": { "type": "string", "minLength": 1 },
    "referenceBaselineConfigPath": { "type": "string", "minLength": 1 },
    "referenceScenarioId": { "type": "string", "minLength": 1 },
    "referenceScenarioConfigPath": { "type": "string", "minLength": 1 },
    "baselineLineage": {
      "type": "object",
      "required": [
        "directReferenceBaselineId",
        "directReferenceBaselineConfigPath",
        "ancestry",
        "sourceScenarioId",
        "sourceScenarioConfigPath"
      ],
      "properties": {
        "directReferenceBaselineId": { "type": "string", "minLength": 1 },
        "directReferenceBaselineConfigPath": { "type": "string", "minLength": 1 },
        "ancestry": { "type": "array", "items": { "type": "string" } },
        "sourceScenarioId": { "type": "string", "minLength": 1 },
        "sourceScenarioConfigPath": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "modelScenario": { "type": "string", "minLength": 1 },
    "resolvedModelName": { "type": "string", "minLength": 1 },
    "workerScenario": { "type": "string", "minLength": 1 },
    "resolvedWorkerCount": { "type": "integer", "minimum": 0 },
    "placementScenario": { "type": "string", "minLength": 1 },
    "resolvedPlacementType": { "type": "string", "minLength": 1 },
    "workloadScenario": { "type": "string", "minLength": 1 },
    "topologyDir": { "type": "string", "minLength": 1 },
    "serverManifest": { "type": "string", "minLength": 1 },
    "namespaceManifest": { "type": "string", "minLength": 1 },
    "storageManifest": { "type": "string", "minLength": 1 },
    "baseUrl": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string" },
    "temperature": { "type": ["number", "string"] },
    "requestTimeoutSeconds": { "type": ["integer", "number", "string"] },
    "resultsRoot": { "type": "string", "minLength": 1 },
    "outputSubdir": { "type": "string" },
    "namespace": { "type": "string" },
    "namespaces": { "type": "array", "items": { "type": "string" } },
    "additionalNamespaces": { "type": "array", "items": { "type": "string" } },
    "runtimeGeneration": {
      "type": "object",
      "required": [
        "generator",
        "parentCycleId",
        "variantId",
        "scenarioFamily",
        "referenceBaselineId",
        "referenceBaselineConfigPath",
        "scenarioId",
        "scenarioConfigPath",
        "generatedBenchmarkConfigPath",
        "schemaId",
        "schemaPath"
      ],
      "properties": {
        "generator": { "type": "string", "minLength": 1 },
        "parentCycleId": { "type": "string", "minLength": 1 },
        "variantId": { "type": "string", "minLength": 1 },
        "scenarioFamily": { "type": "string", "minLength": 1 },
        "referenceBaselineId": { "type": "string", "minLength": 1 },
        "referenceBaselineConfigPath": { "type": "string", "minLength": 1 },
        "scenarioId": { "type": "string", "minLength": 1 },
        "scenarioConfigPath": { "type": "string", "minLength": 1 },
        "generatedBenchmarkConfigPath": { "type": "string", "minLength": 1 },
        "schemaId": { "const": "BENCHMARK_RUNTIME_CONFIG_SCHEMA_V1" },
        "schemaPath": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
