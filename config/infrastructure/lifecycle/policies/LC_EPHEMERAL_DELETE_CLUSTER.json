{
    "schemaVersion": "cluster-lifecycle-policy/v1",
    "lifecyclePolicyId": "LC_EPHEMERAL_DELETE_CLUSTER",
    "policyName": "Provider-Backed Ephemeral Delete Policy",
    "policyCategory": "provider-backed-ephemeral",
    "clusterLifecycleMode": "ephemeral",
    "providerId": "proxmox-k3s",
    "providerManagedLifecycle": true,
    "provisioningRequired": true,
    "destroyClusterAfterCycleDefault": true,
    "description": "Creates a provider-backed K3s cluster for a bounded cycle and plans explicit deletion at the end of the cycle to isolate infrastructure-variation runs.",
    "commands": {
        "createCluster": {
            "required": true,
            "allowed": true,
            "commandName": "proxmox-k3s cluster create"
        },
        "refreshKubeconfig": {
            "required": true,
            "allowed": true,
            "commandName": "proxmox-k3s cluster kubeconfig"
        },
        "deleteCluster": {
            "required": true,
            "allowed": true,
            "commandName": "proxmox-k3s cluster delete"
        },
        "deleteTemplate": {
            "required": false,
            "allowed": false,
            "commandName": "proxmox-k3s template delete"
        }
    },
    "executionGuards": {
        "allowCreate": true,
        "allowDelete": true,
        "requireExplicitDeleteConfirmation": true,
        "allowTemplateDeletion": false,
        "failFastOnMissingProviderConfig": true
    },
    "artifactPolicy": {
        "writeLifecycleManifest": true,
        "writeProvisioningCommandManifest": true,
        "writeDeleteCommandManifest": true,
        "writeLogs": true,
        "defaultLifecycleArtifactRootTemplate": "results/experimental-cycles/{cycleId}/infrastructure/lifecycle",
        "defaultProvisioningLogRootTemplate": "results/experimental-cycles/{cycleId}/infrastructure/provisioning",
        "defaultDeleteLogRootTemplate": "results/experimental-cycles/{cycleId}/infrastructure/deletion"
    },
    "governance": {
        "officialBenchmarkingAllowed": true,
        "comparisonPolicy": "Use this policy when infrastructure profiles must be compared from clean generated cluster instances.",
        "destructiveActionPolicy": "Deletion is expected, but still requires explicit confirmation in command wrappers."
    }
}
