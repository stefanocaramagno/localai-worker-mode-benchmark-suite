{
  "profileId": "PC_CONSOLIDATED_PILOT_CAMPAIGN",
  "description": "Consolidated pilot benchmark profile for the four pilot sweeps. The profile fixes the controlled replica set, the mandatory execution stack already defined in previous points, and stricter phase durations for re-running the pilot campaigns in a comparable way.",
  "outputRoot": "results/experimental-cycles/C0/benchmark/pilot-consolidated",
  "campaignManifestSuffix": "_campaign.json",
  "campaignTextSuffix": "_campaign.txt",
  "stopOnFirstFailure": true,
  "precheckConfig": "config/precheck/profiles/TC_C0_HISTORICAL_FIXED_CLUSTER.json",
  "phaseConfig": "config/phases/profiles/WM_STANDARD_WARMUP_MEASUREMENT.json",
  "protocolConfig": "config/protocol/profiles/EP_STANDARD_BENCHMARK_PROTOCOL.json",
  "clusterCaptureConfig": "config/cluster-capture/profiles/CS_STANDARD_CLUSTER_CAPTURE.json",
  "metricSetConfig": "config/metric-set/profiles/MS_STANDARD_BENCHMARK_METRICS.json",
  "statisticalRigorConfig": "config/statistical-rigor/profiles/SR_REPLICATED_BENCHMARK_RIGOR.json",
  "warmUpDuration": "45s",
  "measurementDuration": "3m",
  "families": {
    "worker-count": {
      "launcherBash": "scripts/load/pilot/start-pilot-worker-count-sweep.sh",
      "launcherPowerShell": "scripts/load/pilot/Start-PilotWorkerCountSweep.ps1",
      "outputRoot": "results/experimental-cycles/C0/benchmark/pilot-consolidated/worker-count",
      "scenarios": [
        "W1",
        "W2",
        "W3",
        "W4"
      ],
      "replicas": [
        "A",
        "B",
        "C"
      ]
    },
    "workload": {
      "launcherBash": "scripts/load/pilot/start-pilot-workload-sweep.sh",
      "launcherPowerShell": "scripts/load/pilot/Start-PilotWorkloadSweep.ps1",
      "outputRoot": "results/experimental-cycles/C0/benchmark/pilot-consolidated/workload",
      "scenarios": [
        "WL1",
        "WL2",
        "WL3"
      ],
      "replicas": [
        "A",
        "B",
        "C"
      ]
    },
    "models": {
      "launcherBash": "scripts/load/pilot/start-pilot-model-sweep.sh",
      "launcherPowerShell": "scripts/load/pilot/Start-PilotModelSweep.ps1",
      "outputRoot": "results/experimental-cycles/C0/benchmark/pilot-consolidated/models",
      "scenarios": [
        "M1",
        "M2",
        "M3",
        "M4"
      ],
      "replicas": [
        "A",
        "B",
        "C"
      ]
    },
    "placement": {
      "launcherBash": "scripts/load/pilot/start-pilot-placement-sweep.sh",
      "launcherPowerShell": "scripts/load/pilot/Start-PilotPlacementSweep.ps1",
      "outputRoot": "results/experimental-cycles/C0/benchmark/pilot-consolidated/placement",
      "scenarios": [
        "PL1",
        "PL2"
      ],
      "replicas": [
        "A",
        "B",
        "C"
      ]
    }
  },
  "launcherResolutionPolicy": {
    "canonicalPilotLaunchersRoot": "scripts/load/pilot",
    "rule": "Pilot campaigns resolve canonical launchers directly from scripts/load/pilot. The historical fixed-cluster scope is expressed by cycle and validation profiles rather than by an additional script-directory layer."
  }
}
