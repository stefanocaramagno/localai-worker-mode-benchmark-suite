{
  "schemaVersion": "placement-profile/v1",
  "placementProfileId": "PL_COLOCATED",
  "profileName": "Co-Located Server and RPC Workers",
  "status": "active",
  "profileRole": "baseline_colocated_placement_profile",
  "strategy": "colocated",
  "placementIntent": "Place the LocalAI server and active RPC workers on the same worker node to minimize intra-application communication distance.",
  "researchQuestion": "How does a compact LocalAI topology behave when communication distance is minimized but CPU and memory contention may increase?",
  "aliases": [
    "colocated_genai_pb_worker_02"
  ],
  "infrastructureCompatibility": {
    "supportedInfrastructureProfiles": [
      "INFRA_C0_1CP_2W_8C16G",
      "INFRA_C1_1CP_2W_8C16G",
      "INFRA_C2_1CP_2W_4C8G",
      "INFRA_C2_1CP_2W_4C16G",
      "INFRA_C2_1CP_2W_8C16G",
      "INFRA_C3_1CP_2W_8C16G",
      "INFRA_C3_1CP_3W_8C16G",
      "INFRA_C3_1CP_4W_8C16G",
      "INFRA_C4_1CP_4W_8C16G",
      "INFRA_C5_1CP_4W_8C16G",
      "INFRA_C6_1CP_4W_8C16G"
    ],
    "requiresWorkerNodePool": true,
    "requiresControlPlaneExclusion": true,
    "minimumWorkerNodes": 1,
    "activeForProviderBackedBaseline": true,
    "activeForProviderBackedPlacementVariation": true
  },
  "selectorPolicy": {
    "selectorMode": "provider_backed_reusable_node_name_compatibility",
