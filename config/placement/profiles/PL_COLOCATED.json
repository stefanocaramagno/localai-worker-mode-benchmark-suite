        "localai-rpc-a": "genai-pb-worker-02"
      },
      "W2": {
        "localai-rpc-a": "genai-pb-worker-02",
        "localai-rpc-b": "genai-pb-worker-02"
      },
      "W3": {
        "localai-rpc-a": "genai-pb-worker-02",
        "localai-rpc-b": "genai-pb-worker-02",
        "localai-rpc-c": "genai-pb-worker-02"
      },
      "W4": {
        "localai-rpc-a": "genai-pb-worker-02",
        "localai-rpc-b": "genai-pb-worker-02",
        "localai-rpc-c": "genai-pb-worker-02",
        "localai-rpc-d": "genai-pb-worker-02"
      }
    },
    "nodePoolPolicy": {
      "nodePool": "workers",
      "allowControlPlaneScheduling": false,
      "preferredSelector": {
