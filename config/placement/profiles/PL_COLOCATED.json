    },
    "rationale": "Stable node names are retained for compatibility with the current Kustomize overlays; label-based node-pool selection is the preferred direction for future generated clusters.",
    "supportedInfrastructureWorkerCounts": [
      2,
      3,
      4
    ],
    "placementType": "colocated_single_worker_node"
  },
  "serverPlacement": {
    "component": "localai-server",
    "expectedNode": "genai-pb-worker-02",
    "selector": {
      "kubernetes.io/hostname": "genai-pb-worker-02"
    },
    "nodePool": "workers",
    "placementNotes": "The current server manifest is still node-name compatible; later topology profiles can replace this with a label-based selector."
  },
  "workerPlacement": {
    "components": [
      "localai-rpc-a",
      "localai-rpc-b",
      "localai-rpc-c",
