  "governanceRules": [
    "Placement profiles describe topology intent and must not change model, workload, benchmark protocol, or infrastructure resources.",
    "Profiles that use stable node names are compatibility profiles; label-based node-pool selection remains the preferred direction for future generated clusters.",
    "Deployment profiles must reference placement profiles explicitly through placementProfileId and placementProfilePath.",
    "Placement profiles referenced by active scenarios must expose concrete Kustomize topology targets."
  ],
  "legacyPlacementScenarioPolicy": {
    "legacyScenarioRoot": "config/scenarios/pilot/placement",
    "legacyScenarioIds": [
      "PL1",
      "PL2"
    ],
    "canonicalIdentifier": "placementProfileId",
    "rationale": "Historical fixed-cluster and legacy pilot workflows may still refer to PL1/PL2. Provider-backed cycles must resolve placement intent through explicit PL_* placement profiles.",
    "legacyScenarioIdentifierField": "legacyScenarioId",
    "legacyScenarioIdsAreCanonicalProfiles": false,
    "providerBackedCyclesMayUseLegacyScenarioIds": false,
    "resolutionMode": "legacy_scenario_id_to_canonical_placement_profile_id"
  },
  "legacyPlacementScenarioAliases": [
    {
      "legacyScenarioId": "PL1",
      "legacyScenarioPath": "config/scenarios/pilot/placement/PL1.json",
      "canonicalPlacementProfileId": "PL_COLOCATED",
      "canonicalPlacementProfilePath": "config/placement/profiles/PL_COLOCATED.json",
      "identifierClass": "historical_fixed_cluster_scenario",
      "canonicalIdentifierField": "placementProfileId"
    },
    {
      "legacyScenarioId": "PL2",
      "legacyScenarioPath": "config/scenarios/pilot/placement/PL2.json",
      "canonicalPlacementProfileId": "PL_DISTRIBUTED_TWO_NODE",
      "canonicalPlacementProfilePath": "config/placement/profiles/PL_DISTRIBUTED_TWO_NODE.json",
      "identifierClass": "historical_fixed_cluster_scenario",
      "canonicalIdentifierField": "placementProfileId"
    }
  ],
  "identifierPolicy": {
    "canonicalIdentifierField": "placementProfileId",
    "canonicalPlacementProfilePrefix": "PL_",
    "providerBackedScenarioIdentifierField": "scenarioId",
    "providerBackedScenarioPrefix": "PLC_",
    "historicalFixedClusterScenarioPrefix": "PL",
    "provisioningValidationPrefix": "PV_",
    "rules": [
      "Use placementProfileId for reusable placement profiles and deployment resolution.",
      "Use scenarioId for campaign-specific placement-variation scenarios.",
      "Use PL1/PL2 only as historical fixed-cluster scenario identifiers.",
      "Do not use PV_* for placement scenarios because PV_* is reserved for provisioning-validation profiles."
    ]
  }
}
