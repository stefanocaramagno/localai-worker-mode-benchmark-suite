  "properties": {
    "runConventionId": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "timezone": {
      "type": "string"
    },
    "runIdFormat": {
      "type": "string"
    },
    "utcTimestampCompactPattern": {
      "type": "string"
    },
    "runManifestSuffix": {
      "type": "string"
    },
    "csvPrefixFormat": {
      "type": "string"
    },
    "replicaPolicy": {
      "type": "object"
    },
    "requiredRunMetadata": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
