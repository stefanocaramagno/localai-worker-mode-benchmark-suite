{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "RUN_CONVENTION_PROFILE_SCHEMA_V1.json",
  "title": "Run convention profiles profile",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "runConventionId",
    "version",
    "timezone",
    "runIdFormat",
    "utcTimestampCompactPattern",
    "runManifestSuffix",
    "csvPrefixFormat",
    "replicaPolicy",
    "requiredRunMetadata"
