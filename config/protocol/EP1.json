{
  "profileId": "EP1",
  "description": "Standard benchmark execution protocol for LocalAI benchmark runs. The launcher must always resolve and publish the same ordered sequence: controlled cleanup, scenario deployment, technical pre-check, API smoke validation, optional warm-up, measurement, client-side artifact collection, automated required cluster-side collection, automated required final snapshot, and controlled cleanup or restore placeholder.",
  "apiSmokeEnabledDefault": true,
  "apiSmokeScriptRelativePathBash": "scripts/validation/smoke/test-localai-worker-mode.sh",
  "apiSmokeScriptRelativePathPowerShell": "scripts/validation/smoke/Test-LocalAIWorkerMode.ps1",
  "protocolManifestSuffix": "_protocol.json",
  "protocolTextSuffix": "_protocol.txt",
  "steps": [
    {
      "stepId": "S01",
      "name": "cleanup_controlled",
      "mode": "manual"
    },
    {
      "stepId": "S02",
      "name": "deploy_scenario",
      "mode": "manual"
    },
    {
      "stepId": "S03",
      "name": "technical_precheck",
      "mode": "automated"
    },
    {
      "stepId": "S04",
      "name": "api_smoke_validation",
      "mode": "automated"
    },
    {
      "stepId": "S05",
      "name": "warm_up",
      "mode": "automated_optional"
    },
    {
      "stepId": "S06",
      "name": "measurement",
      "mode": "automated"
    },
    {
      "stepId": "S07",
      "name": "collect_client_metrics",
      "mode": "automatic_artifact"
    },
    {
      "stepId": "S08",
      "name": "collect_cluster_metrics",
      "mode": "automated_required"
    },
    {
      "stepId": "S09",
      "name": "final_snapshot",
      "mode": "automated_required"
    },
    {
      "stepId": "S10",
      "name": "cleanup_or_restore",
      "mode": "manual_controlled_placeholder"
    }
  ]
}
