{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "localai-cluster-capture-profile/v1",
  "title": "LocalAI Cluster Capture Profile",
  "type": "object",
  "required": [
    "schemaVersion",
    "profileId",
    "description",
    "collectorScriptRelativePathBash",
    "collectorScriptRelativePathPowerShell",
    "preStageSuffix",
    "postStageSuffix",
    "manifestSuffix",
    "textSuffix",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "profileStatus": {
      "type": "string"
    },
    "schemaPath": {
      "type": "string"
    },
    "profileScope": {
      "type": "object"
    },
    "collectorScriptRelativePathBash": {
      "type": "string"
    },
    "collectorScriptRelativePathPowerShell": {
      "type": "string"
    },
    "preStageSuffix": {
      "type": "string"
    },
    "postStageSuffix": {
      "type": "string"
    },
    "manifestSuffix": {
      "type": "string"
    },
    "textSuffix": {
      "type": "string"
    },
    "textSummarySuffix": {
      "type": "string"
    },
    "observabilityMode": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "namespaces": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "namespace": {
      "type": "string"
    },
    "additionalNamespaces": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "namespaceCollectionPolicy": {
      "type": "object"
    },
    "networkAwareEvidence": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "command",
          "outputSuffix"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "outputSuffix": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
